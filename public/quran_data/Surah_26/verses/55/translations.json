    "translator": "Abdul Rehman Killani",
    "text": "جو ہمیں غصہ چڑھا رہے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "اور یہ ہمیں غصہ دلا رہے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "اور بلاشبہ یہ ہمیں یقینا غصہ دلانے والے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "اور بلاشبہ وہ ضرور ہمیں غصہ دلانے والے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
