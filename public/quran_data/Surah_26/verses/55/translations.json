  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "اور انہوں نے ہم کو بہت ناراض کیا ہے ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "اور بلاشبہ یہ لوگ البتہ ہمیں غصہ دلارہے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "اور حقیقت یہ ہے کہ انہوں نے ہمارے دل جلائے ہوئے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "اور یہ ہمیں غصہ دلا رہے ہیں۔"
