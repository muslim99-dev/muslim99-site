[
  {
    "translator": "Dr Farhat Hashmi",
    "words": [
      {
        "arabic": "فَتَبَسَّمَ",
        "urdu": "تو وہ مسکرا دیا"
      },
      {
        "arabic": "ضَاحِکًا",
        "urdu": "ہنستے ہوئے"
      },
      {
        "arabic": "مِّنۡ قَوۡلِہَا",
        "urdu": "اس کی بات سے"
      },
      {
        "arabic": "وَقَالَ",
        "urdu": "اور اس نے کہا"
      },
      {
        "arabic": "رَبِّ",
        "urdu": "اے میرے رب"
      },
      {
        "arabic": "اَوۡزِعۡنِیۡۤ",
        "urdu": "توفیق دے مجھے"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "کہ"
      },
      {
        "arabic": "اَشۡکُرَ",
        "urdu": "میں شکر ادا کروں"
      },
      {
        "arabic": "نِعۡمَتَکَ",
        "urdu": "تیری نعمت کا"
      },
      {
        "arabic": "الَّتِیۡۤ",
        "urdu": "وہ جو"
      },
      {
        "arabic": "اَنۡعَمۡتَ",
        "urdu": "انعام کی تو نے"
      },
      {
        "arabic": "عَلَیَّ",
        "urdu": "مجھ پر"
      },
      {
        "arabic": "وَعَلٰی",
        "urdu": "اور اوپر"
      },
      {
        "arabic": "وَالِدَیَّ",
        "urdu": "میرے والدین کے"
      },
      {
        "arabic": "وَاَنۡ",
        "urdu": "اور یہ کہ"
      },
      {
        "arabic": "اَعۡمَلَ",
        "urdu": "میں عمل کروں"
      },
      {
        "arabic": "صَالِحًا",
        "urdu": "نیک"
      },
      {
        "arabic": "تَرۡضٰىہُ",
        "urdu": "تو راضی ہوجائے جس سے"
      },
      {
        "arabic": "وَاَدۡخِلۡنِیۡ",
        "urdu": "اور داخل کر مجھے"
      },
      {
        "arabic": "بِرَحۡمَتِکَ",
        "urdu": "اپنی رحمت کے ساتھ"
      },
      {
        "arabic": "فِیۡ عِبَادِکَ",
        "urdu": "اپنے بندوں میں"
      },
      {
        "arabic": "الصّٰلِحِیۡنَ",
        "urdu": "جو نیک ہیں"
      }
    ]
  },
