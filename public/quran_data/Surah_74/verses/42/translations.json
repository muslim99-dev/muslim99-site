[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "تمہیں دوزخ میں کس چیز نے ڈالا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "تم لوگوں کو کس چیز نے جہنم میں ڈالا ؟"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "تمہیں کیا چیز دوزخ میں لے گئی ؟"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "کہ تم دوزخ میں کیوں پڑے؟"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "تمہیں کس چیز نے سقر میں داخل کردیا ؟"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "تمہیں کس چیزنے دوزخ میں داخل کیا۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "( سوال کریں گے: )  تمہیں کیا چیز دوزخ میں لے گئی؟"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "(سوال کریں گے) تمہیں کیا چیز دوزخ میں لے گئی"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "کہ تمہیں کیا چیز دوزخ میں لے گئی؟"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "آخر تمہیں کس چیز نے جہنمّ میں پہنچادیا ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "تمہیں کیا چیز دوزخ میں لے گئی؟"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "تم لوگوں کو کیا چیز جہنم میں لائی؟"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "کہ  :  تمہیں کس چیز نے دوزخ میں داخل کردیا؟"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "کہ تم دوزخ میں کیوں پڑے ہو ؟"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "’’تمہیں کیا چیزجہنم میں لے گئی؟‘‘"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "تمہیں کیا بات دوزخ میں لے گئی ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "۔   ( اور کہیں گے: )  تمہیں کیا چیز دوزخ میں لے گئی"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "\"तुम्हे क्या चीज़ सक़र (जहन्नम) में ले आई?\""
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "[And asking them], \"What put you into Saqar?\""
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "[And asking them], \"What put you into Saqar?\""
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "“What drove you to Hell?”"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "\"What has caused you to enter Hell\""
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "What hath brought you to this burning?"
  },
  {
