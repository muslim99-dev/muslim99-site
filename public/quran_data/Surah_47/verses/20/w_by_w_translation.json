        "arabic": "وَیَقُوۡلُ",
        "urdu": "اور کہتے ہیں"
      },
      {
        "arabic": "الَّذِیۡنَ",
        "urdu": "وہ لوگ جو"
      },
      {
        "arabic": "اٰمَنُوۡا",
        "urdu": "ایمان لائے"
      },
      {
        "arabic": "لَوۡلَا",
        "urdu": "کیوں نہیں"
      },
      {
        "arabic": "نُزِّلَتۡ",
        "urdu": "نازل کی گئی"
      },
      {
        "arabic": "سُوۡرَۃٌ",
        "urdu": "کوئی سورت"
      },
      {
        "arabic": "فَاِذَاۤ",
        "urdu": "پھر جب"
      },
      {
        "arabic": "اُنۡزِلَتۡ",
        "urdu": "نازل کی جاتی ہے"
      },
      {
        "arabic": "سُوۡرَۃٌ",
        "urdu": "کوئی سورت"
      },
      {
        "arabic": "مُّحۡکَمَۃٌ",
        "urdu": "محکم"
      },
      {
        "arabic": "وَّذُکِرَ",
        "urdu": "اور ذکر کیا جاتا ہے"
      },
      {
        "arabic": "فِیۡہَا",
        "urdu": "اس میں"
      },
      {
        "arabic": "الۡقِتَالُ",
        "urdu": "جنگ کا"
      },
      {
        "arabic": "رَاَیۡتَ",
        "urdu": "آپ دیکھیں گے"
      },
      {
        "arabic": "الَّذِیۡنَ",
        "urdu": "ان لوگوں کو"
      },
      {
        "arabic": "فِیۡ قُلُوۡبِہِمۡ",
        "urdu": "جن کے دلوں میں"
      },
      {
        "arabic": "مَّرَضٌ",
        "urdu": "بیماری ہے"
      },
      {
        "arabic": "یَّنۡظُرُوۡنَ",
        "urdu": "وہ دیکھ رہے ہوں گے"
      },
      {
        "arabic": "اِلَیۡکَ",
        "urdu": "آپ کی طرف"
      },
      {
        "arabic": "نَظَرَ",
        "urdu": "ـجیسےـدیکھنا"
      },
      {
        "arabic": "الۡمَغۡشِیِّ",
        "urdu": "اس کا غشی طاری ہو گئی ہو"
      },
      {
        "arabic": "عَلَیۡہِ",
        "urdu": "جس پر"
      },
      {
        "arabic": "مِنَ الۡمَوۡتِ",
        "urdu": "موت کی وجہ سے"
      },
      {
        "arabic": "فَاَوۡلٰی",
        "urdu": "تو تباہی/ہلاکت ہے"
      },
      {
        "arabic": "لَہُمۡ",
        "urdu": "ان کے لیے"
      }
    ]
  },
