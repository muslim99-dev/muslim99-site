        "urdu": "کیا جلدی کی تم نے"
      },
      {
        "arabic": "اَمۡرَ",
        "urdu": "حکم سے"
      },
      {
        "arabic": "رَبِّکُمۡ",
        "urdu": "اپنے رب کے"
      },
      {
        "arabic": "وَاَلۡقَی",
        "urdu": "اور اس نے ڈال دیں"
      },
      {
        "arabic": "الۡاَلۡوَاحَ",
        "urdu": "تختیاں"
      },
      {
        "arabic": "وَاَخَذَ",
        "urdu": "اور اس نے پکڑ لیا"
      },
      {
