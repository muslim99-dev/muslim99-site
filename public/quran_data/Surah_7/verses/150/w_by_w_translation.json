      },
      {
        "arabic": "تُشۡمِتۡ",
        "urdu": "تو ہنسا"
      },
      {
        "arabic": "بِیَ",
        "urdu": "مجھ پر"
      },
      {
        "arabic": "الۡاَعۡدَآءَ",
        "urdu": "دشمنوں کو"
      },
      {
        "arabic": "وَلَا",
        "urdu": "اور نہ"
      },
      {
        "arabic": "تَجۡعَلۡنِیۡ",
        "urdu": "تو  شامل کر مجھے"
      },
      {
        "arabic": "مَعَ الۡقَوۡمِ",
        "urdu": "ساتھ ان لوگوں کے"
      },
      {
        "arabic": "الظّٰلِمِیۡنَ",
        "urdu": "جو  ظالم ہیں"
      }
