        "arabic": "مِنۡ قَوۡمِہٖ",
        "urdu": "اس کی قوم میں سے"
      },
      {
        "arabic": "لَنُخۡرِجَنَّکَ",
        "urdu": "البتہ ہم ضرور نکال دیں گے تجھے"
