      },
      {
        "arabic": "فِرۡعَوۡنُ",
        "urdu": "فرعون"
      },
      {
        "arabic": "وَقَوۡمُہٗ",
        "urdu": "اور اس کی قوم کے لوگ"
      },
      {
        "arabic": "وَمَا",
        "urdu": "اور جو کچھ"
