        "arabic": "وَاَوۡرَثۡنَا",
        "urdu": "اور وارث بنا دیا ہم نے"
      },
      {
        "arabic": "الۡقَوۡمَ",
        "urdu": "ان لوگوں کو"
      },
      {
        "arabic": "الَّذِیۡنَ",
        "urdu": "وہ جو"
      },
      {
        "arabic": "کَانُوۡا",
        "urdu": "تھے وہ"
      },
      {
        "arabic": "یُسۡتَضۡعَفُوۡنَ",
        "urdu": "وہ کمزور سمجھے جاتے"
      },
      {
        "arabic": "مَشَارِقَ الۡاَرۡضِ",
        "urdu": "زمین کے مشرقوں کا"
      },
      {
        "arabic": "وَمَغَارِبَہَا",
        "urdu": "اور اس کے مغربوں کا"
      },
      {
        "arabic": "الَّتِیۡ",
        "urdu": "وہ جو"
      },
      {
        "arabic": "بٰرَکۡنَا",
        "urdu": "برکت دی تھی ہم نے"
      },
      {
        "arabic": "فِیۡہَا",
        "urdu": "اس میں"
      },
      {
        "arabic": "وَتَمَّتۡ",
        "urdu": "اور پوری ہوگئی"
      },
      {
        "arabic": "کَلِمَتُ",
