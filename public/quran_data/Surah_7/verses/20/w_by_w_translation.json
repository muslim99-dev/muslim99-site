    "words": [
      {
        "arabic": "فَوَسۡوَسَ",
        "urdu": "پس وسوسہ ڈالا"
      },
      {
        "arabic": "لَہُمَا",
        "urdu": "ان دونوں کے لئے"
      },
      {
        "arabic": "الشَّیۡطٰنُ",
        "urdu": "شیطان نے"
      },
      {
        "arabic": "لِیُبۡدِیَ",
        "urdu": "تاکہ وہ ظاہر کر دے"
      },
      {
        "arabic": "لَہُمَا",
        "urdu": "ان دونو کے لیے"
      },
      {
        "arabic": "مَاوٗرِیَ",
        "urdu": "جو  چھپائی گئی تھا"
      },
      {
        "arabic": "عَنۡہُمَا",
        "urdu": "ان دونوں سے"
      },
      {
        "arabic": "مِنۡ سَوۡاٰتِہِمَا",
        "urdu": "شرم گاہیں  ان دونوں کی"
      },
      {
        "arabic": "وَقَالَ",
        "urdu": "اور کہا"
      },
      {
        "arabic": "مَا",
        "urdu": "نہیں"
      },
      {
        "arabic": "نَہٰکُمَا",
        "urdu": "روکا تم دونوں کو"
      },
      {
        "arabic": "رَبُّکُمَا",
        "urdu": "تمہارے رب نے"
      },
      {
        "arabic": "عَنۡ ہٰذِہِ الشَّجَرَۃِ",
        "urdu": "اس درخت سے"
      },
      {
        "arabic": "اِلَّاۤ",
        "urdu": "مگر"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "یہ کہ"
      },
      {
        "arabic": "تَکُوۡنَا",
        "urdu": "تم دونوں ہو جاؤ"
      },
      {
        "arabic": "مَلَکَیۡنِ",
        "urdu": "دو فرشتے"
      },
      {
        "arabic": "اَوۡ",
        "urdu": "یا"
      },
      {
        "arabic": "تَکُوۡنَا",
        "urdu": "تم دونوں ہو جاؤ"
      },
      {
        "arabic": "مِنَ الۡخٰلِدِیۡنَ",
        "urdu": "ہمیشہ رہنے والوں میں سے"
      }
    ]
  },
