    "words": [
      {
        "arabic": "فَدَلّٰىہُمَا",
        "urdu": "پس اس نے کھینچ لیا ان دونوں کو"
      },
      {
        "arabic": "بِغُرُوۡرٍ",
        "urdu": "ساتھ  دھوکے کے"
      },
      {
        "arabic": "فَلَمَّا",
        "urdu": "پھر جب"
      },
      {
        "arabic": "ذَاقَا",
        "urdu": "دونوں نے چکھا"
      },
      {
        "arabic": "الشَّجَرَۃَ",
        "urdu": "اس درخت کو"
      },
      {
        "arabic": "بَدَتۡ",
        "urdu": "ظاہر ہوگئیں"
      },
      {
        "arabic": "لَہُمَا",
        "urdu": "ان دونوں کے لئے"
      },
      {
        "arabic": "سَوۡاٰتُہُمَا",
        "urdu": "شرمگاہیں ان دونو کی"
      },
      {
        "arabic": "وَطَفِقَا",
        "urdu": "اور وہ دونوں شروع ہوگئے"
      },
      {
        "arabic": "یَخۡصِفٰنِ",
        "urdu": "وہ دونو  چپکانےلگے"
      },
      {
        "arabic": "عَلَیۡہِمَا",
        "urdu": "اپنے اوپر"
      },
      {
        "arabic": "مِنۡ وَّرَقِ",
        "urdu": "پتوں سے"
      },
      {
        "arabic": "الۡجَنَّۃِ",
        "urdu": "جنت کے"
      },
      {
        "arabic": "وَنَادٰىہُمَا",
        "urdu": "اور پکارا ان دونوں کو"
      },
      {
        "arabic": "رَبُّہُمَاۤ",
        "urdu": "ان کے رب نے"
      },
      {
        "arabic": "اَلَمۡ",
        "urdu": "کیا نہیں"
      },
      {
        "arabic": "اَنۡہَکُمَا",
        "urdu": "میں نے روکا تھا تم دونوں کو"
      },
      {
        "arabic": "عَنۡ تِلۡکُمَاالشَّجَرَۃِ",
        "urdu": "اس  درخت سے"
      },
      {
        "arabic": "وَاَقُلۡ",
        "urdu": "اور میں نے  کہا تھا"
      },
      {
        "arabic": "لَّکُمَاۤ",
        "urdu": "تم دونوں کو"
      },
      {
        "arabic": "اِنَّ",
        "urdu": "بےشک"
      },
      {
        "arabic": "الشَّیۡطٰنَ",
        "urdu": "شیطان"
      },
      {
        "arabic": "لَکُمَا",
        "urdu": "تم دونوں کا"
      },
      {
        "arabic": "عَدُوٌّ",
        "urdu": "دشمن ہے"
      },
      {
        "arabic": "مُّبِیۡنٌ",
        "urdu": "کھلم  کھلا"
      }
    ]
