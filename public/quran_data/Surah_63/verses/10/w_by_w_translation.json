      },
      {
        "arabic": "اَحَدَکُمُ",
        "urdu": "تم میں سے کسی ایک کو"
      },
      {
        "arabic": "الۡمَوۡتُ",
        "urdu": "موت"
      },
      {
        "arabic": "فَیَقُوۡلَ",
