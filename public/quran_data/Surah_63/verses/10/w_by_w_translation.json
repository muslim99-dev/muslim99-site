      },
      {
        "arabic": "قَرِیۡبٍ",
        "urdu": "قریب کے"
      },
      {
        "arabic": "فَاَصَّدَّقَ",
        "urdu": "تو میں صدقہ کرتا"
      },
      {
        "arabic": "وَاَکُنۡ",
        "urdu": "اور میں ہو جاتا"
      },
      {
        "arabic": "مِّنَ الصّٰلِحِیۡنَ",
        "urdu": "نیک لوگوں میں سے"
