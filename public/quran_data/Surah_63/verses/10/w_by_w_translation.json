        "arabic": "وَ اَنۡفِقُوۡا",
        "urdu": "اور خرچ کرو"
      },
      {
        "arabic": "مِنۡ مَّا",
        "urdu": "اس میں سے جو"
      },
      {
        "arabic": "رَزَقۡنٰکُمۡ",
        "urdu": "رزق دیا ہم نے تمہیں"
      },
      {
        "arabic": "مِّنۡ قَبۡلِ",
        "urdu": "اس سے پہلے"
      },
      {
