    "words": [
      {
        "arabic": "وَمَاۤ",
        "urdu": "اور نہیں"
      },
      {
        "arabic": "اَرۡسَلۡنَا",
        "urdu": "بھیجا ہم نے"
      },
      {
        "arabic": "مِنۡ قَبۡلِکَ",
        "urdu": "آپ سے پہلے"
      },
      {
        "arabic": "اِلَّا",
        "urdu": "مگر"
      },
      {
        "arabic": "رِجَالًا",
        "urdu": "مردوں کو"
      },
      {
        "arabic": "نُّوۡحِیۡۤ",
        "urdu": "ہم وحی کرتے تھے"
      },
      {
        "arabic": "اِلَیۡہِمۡ",
        "urdu": "طرف ان کے"
      },
      {
        "arabic": "مِّنۡ اَہۡلِ الۡقُرٰی",
        "urdu": "بستی والوں میں سے"
      },
      {
        "arabic": "اَفَلَمۡ",
        "urdu": "کیا پھر نہیں"
      },
      {
        "arabic": "یَسِیۡرُوۡا",
        "urdu": "وہ چلے پھرے"
      },
      {
        "arabic": "فِی الۡاَرۡضِ",
        "urdu": "زمین میں"
      },
      {
        "arabic": "فَیَنۡظُرُوۡا",
        "urdu": "تو وہ دیکھتے"
      },
      {
        "arabic": "کَیۡفَ",
        "urdu": "کس طرح"
      },
      {
        "arabic": "کَانَ",
        "urdu": "ہوا"
      },
      {
        "arabic": "عَاقِبَۃُ",
        "urdu": "انجام"
      },
      {
        "arabic": "الَّذِیۡنَ",
        "urdu": "ان کا جو"
      },
      {
        "arabic": "مِنۡ قَبۡلِہِمۡ",
        "urdu": "ان سے پہلے تھے"
      },
      {
        "arabic": "وَلَدَارُ",
        "urdu": "اور البتہ گھر"
      },
      {
        "arabic": "الۡاٰخِرَۃِ",
        "urdu": "آخرت کا"
      },
      {
        "arabic": "خَیۡرٌ",
        "urdu": "بہتر ہے"
      },
      {
        "arabic": "لِّلَّذِیۡنَ",
        "urdu": "ان کے لئے جو"
      },
      {
        "arabic": "اتَّقَوۡا",
        "urdu": "تقویٰ  کریں"
      },
      {
        "arabic": "اَفَلَا",
        "urdu": "کیا پھر نہیں"
      },
      {
        "arabic": "تَعۡقِلُوۡنَ",
        "urdu": "تم عقل سے کام لیتے"
      }
    ]
  },
