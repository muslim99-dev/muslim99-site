      },
      {
        "arabic": "بِاللّٰہِ",
        "urdu": "ساتھ اللہ کے"
      },
      {
        "arabic": "مِنۡ شَیۡءٍ",
        "urdu": "کسی چیز کو"
      },
      {
        "arabic": "ذٰلِکَ",
        "urdu": "یہ"
      },
      {
        "arabic": "مِنۡ فَضۡلِ",
        "urdu": "فضل میں سے ہے"
      },
      {
        "arabic": "اللّٰہِ",
        "urdu": "اللہ کے"
      },
      {
        "arabic": "عَلَیۡنَا",
        "urdu": "ہم پر"
      },
      {
        "arabic": "وَعَلَی النَّاسِ",
        "urdu": "اور لوگوں پر"
      },
      {
        "arabic": "وَلٰکِنَّ",
        "urdu": "اور لیکن"
      },
      {
        "arabic": "اَکۡثَرَ",
