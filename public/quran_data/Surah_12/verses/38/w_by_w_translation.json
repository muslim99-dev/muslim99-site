        "arabic": "وَاتَّبَعۡتُ",
        "urdu": "اور میں نے پیروی کی"
      },
      {
        "arabic": "مِلَّۃَ",
        "urdu": "دین کی"
      },
      {
        "arabic": "اٰبَآءِیۡۤ",
        "urdu": "اپنے آباؤ اجداد کے"
      },
      {
        "arabic": "اِبۡرٰہِیۡمَ",
        "urdu": "ابراہیم"
      },
      {
        "arabic": "وَاِسۡحٰقَ",
        "urdu": "اور اسحاق"
      },
      {
        "arabic": "وَیَعۡقُوۡبَ",
        "urdu": "اور یعقوب کے"
      },
      {
        "arabic": "مَا",
        "urdu": "نہیں ہے ہمارے لیے"
      },
      {
        "arabic": "کَانَ",
        "urdu": "نہیں"
      },
      {
        "arabic": "لَنَاۤ",
