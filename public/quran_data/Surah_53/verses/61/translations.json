[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "۔  ( بلکہ )  تم کھیل رہے ہو ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "اور تم خوش فعلیاں کر رہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "تم کھیل کود میں پڑ کر اس سے غافل ہوچکے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "اور تم غفلت میں پڑ رہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "وَتَضْحَکُوْنَ وَلَاتَبْکُوْنَ یعنی بجائے اس کے کہ تم یہ سن کر ڈر جاتے کہ کہیں ہم پر بھی ایسا عذاب نہ آجائے اور رونے لگتے ، الٹا اس کا مذاق اڑاتے اور ہنستے ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "اورتم غافل ہو"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "اور تم مدہوش پڑے ہو!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "اور تم مدہوش پڑے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "اور تم غفلت میں مدہوش ہو ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "اور تم بالکل غافل ہو"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "اور گا بجا کر انہیں ٹالتے 54 ہو؟"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "اور تم غفلت و تکبر سے کھیل تماشے میں پڑے ہوئے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "جبکہ تم تکبر کے ساتھ کھیل کود میں پڑے ہوئے ہو؟"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "اور تم غفلت میں پڑ رہے ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "اور غفلت میں مبتلا ہنس کھیل رہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "اور تم کھیل میں پڑے ہو ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "اور تم  ( غفلت کی )  کھیل میں پڑے ہو"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "जबकि तुम घमंडी और ग़ाफिल हो"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "While you are proudly sporting?"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "While you are proudly sporting?"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "Will you occupy yourselves simply in merriment?"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "While you are Samidun."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "While ye amuse yourselves?"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "indulging in carelessly idle games?"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "While you are indulging in varieties."
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Wasting your time in vanities?"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "while you are engaged in vain play?"
  }
]