[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "جو منہ اور سر کی کھال کھینچ لانے والی ہے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "جو کلیجوں کو کھینچ لے گی۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "کھالوں کو ادھیڑ دینے والی"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "کھال ادھیڑ ڈالنے والی"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "منہ اور سر کی کھال کو اتار کھینچنے والی ہے۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "جو منہ اورسر کی کھال کواتارکھینچنے والی ہے۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "چمڑی ادھیڑ لے گی"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "جو چمڑی ادھیڑ ڈالے گی"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "جو کھال کو ادھیڑ کر رکھ دے گا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "کھال اتار دینے والی"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "جو گوشت پوست کو چاٹ جائے گی  ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "گوشت پوست کو اُدھیڑ ڈالنے والی"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "جو کھال اتار لے گی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "کھال ادھیڑ ڈالنے والی۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "کھالوں کو ادھیڑدینے والی"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "کھال اتار لینے والی بلارہی ہے  ( ف۱۵ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "سر اور تمام اَعضائے بدن کی کھال اتار دینے والی ہے"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "जो मांस और त्वचा को चाट जाएगी,"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "A remover of exteriors."
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "A remover of exteriors."
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "that will strip off the scalp."
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Nazza`ah the Shawa!"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Eager to roast;"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "will strip-off the flesh"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Dragging by the head,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Plucking out (his being) right to the skull!-"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "that will pull out the skin of the scalp."
  }
]