[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "اور بہت فساد مچا رکھا تھا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "سو انہوں نے ان میں بکثرت فساد پھیلا دیا تھا۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "اور ان میں بہت فساد مچا دیا"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "اور ان میں بہت سی خرابیاں کرتے تھے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "پس انھوں نے ان میں بہت زیادہ فساد پھیلا دیا۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "پس انہوں نے اُن میں بہت زیادہ فسادپھیلایا۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "اور ان میں بڑی اودھم مچائی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "اور ان میں بہت فساد مچایا"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "اوران میں بہت فساد پھیلایا تھا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "اور خوب فساد کیا"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "اور ان میں بہت فساد پھیلا تھا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پس ان میں فساد ہی کو کثرت سے کیا"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "اور ان میں بہت فساد مچایا تھا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "اور ان میں بہت سی خرابیاں کرتے تھے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "اور ان میں بہت فسادمچادیا"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ۱۲ )  پھر ان میں بہت فساد پھیلایا  ( ف۱٤ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "پھر ان میں بڑی فساد انگیزی کی تھی"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "और उन में बहुत बिगाड़ पैदा किया"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "And increased therein the corruption."
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "And increased therein the corruption."
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "spreading in them much corruption?"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "And made therein much mischief."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "And multiplied iniquity therein?"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "and spread much corruption in the land."
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "So they made great mischief therein?"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "And heaped therein mischief (on mischief)."
  },
  {
    "language": "English",
