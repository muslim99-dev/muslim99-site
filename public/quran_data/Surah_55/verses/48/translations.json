[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "۔   ( دونوں جنتیں )  بہت سی ٹہنیوں اور شاخوں والی ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "دونوں بہت سی شاخوں والی ہوں گی۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "وہ دونوں باغ لمبی لمبی اور بڑی بڑی شاخوں والے ہوں گے"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "ان دونوں میں بہت سی شاخیں (یعنی قسم قسم کے میووں کے درخت ہیں)"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "دونوں بہت شاخوں والے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "دونوں ہی بہت شاخوں والے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "دونوں نہایت کثیر شاخوں والے ہوں گے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "نہایت ہری بھری ڈالیوں والے"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "دونوں باغ بہت سی شاخوں والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "اور دونوں باغات درختوں کی ٹہنیوں سے ہرے بھرے میوؤں سے لدے ہوں گے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "ہری بھری ڈالیوں سے بھر پور  ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "دونوں باغ  ( پھل دار )  ٹہنیوں والے  ( ہوں گے )"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "دونوں باغ شاخوں سے بھرے ہوئے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "ان دونوں میں بہت سی شاخیں ہیں یعنی قسم قسم کے میووں کے درخت ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "وہ  ( دونوں جنتیں  )  بہت سی شاخوں والی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "بہت سی ڈالوں والیاں  ( ف۳۹ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "جو دونوں  ( سرسبز و شاداب )  گھنی شاخوں والی  ( جنتیں )  ہیں"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "घनी डालियों वाले;"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Having [spreading] branches."
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Having [spreading] branches."
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "These Gardens will abound in green, blooming branches."
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "With Afnan."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Of spreading branches."
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "full of various trees."
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Having in them various kinds."
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Containing all kinds (of trees and delights);-"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "__ both having branches."
  }
]