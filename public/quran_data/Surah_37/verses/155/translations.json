  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "کیا تمہیں ہوش نہیں آتا  ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "کیا پھر تم لوگ نصیحت حاصل نہیں کرتے"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "بھلا کیا تم اتنا بھی دھیان نہیں دیتے؟"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "بھلا تم غور کیوں نہیں کرتے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "کچھ بھی ہوش نہیں کرتے"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "تو کیا دھیان نہیں کرتے  ( ف۱٤۰ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "کیا تم غور نہیں کرتے؟"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "तो क्या तुम होश से काम नहीं लेते?"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Then will you not be reminded?"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Then will you not be reminded?"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "Will you then not take heed?"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Will you not then remember"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Will ye not then reflect?"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "Do you not understand?"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Will you not then mind?"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Will ye not then receive admonition?"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "Then, is it that you do not think about it?"
  }
