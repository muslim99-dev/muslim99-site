  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "کیا تم اتنا بھی نہیں سمجھتے؟"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "کیا تم غور و فکر نہیں کررہے ہو"
