    "words": [
      {
        "arabic": "وَلِسُلَیۡمٰنَ",
        "urdu": "اور سلیمان کے لیے"
      },
      {
        "arabic": "الرِّیۡحَ",
        "urdu": "ہوا کو (مسخر کیا)"
      },
      {
        "arabic": "غُدُوُّہَا",
        "urdu": "صبح کا چلنا اس کا"
      },
      {
        "arabic": "شَہۡرٌ",
        "urdu": "ایک ماہ کا"
      },
      {
        "arabic": "وَّرَوَاحُہَا",
        "urdu": "اور شام کا چلنا اس کا"
      },
      {
        "arabic": "شَہۡرٌ",
        "urdu": "ایک ماہ کا"
      },
      {
        "arabic": "وَاَسَلۡنَا",
        "urdu": "اور بہادیا ہم نے"
      },
      {
        "arabic": "لَہٗ",
        "urdu": "اس کے لیے"
      },
      {
        "arabic": "عَیۡنَ",
        "urdu": "چشمہ"
      },
      {
        "arabic": "الۡقِطۡرِ",
        "urdu": "پگھلے ہوئے تانبے کا"
      },
      {
        "arabic": "وَمِنَ الۡجِنِّ",
        "urdu": "اور جنوں میں سے"
      },
      {
        "arabic": "مَنۡ",
        "urdu": "جو"
      },
      {
        "arabic": "یَّعۡمَلُ",
        "urdu": "کام کرتے تھے"
      },
      {
        "arabic": "بَیۡنَ یَدَیۡہِ",
        "urdu": "اس کے سامنے"
      },
      {
        "arabic": "بِاِذۡنِ",
        "urdu": "اذن سے"
      },
      {
        "arabic": "رَبِّہٖ",
        "urdu": "اس کے رب کے"
      },
      {
        "arabic": "وَمَنۡ",
        "urdu": "اور جو"
      },
      {
        "arabic": "یَّزِغۡ",
        "urdu": "سرکشی کرتا"
      },
      {
        "arabic": "مِنۡہُمۡ",
        "urdu": "ان میں سے"
      },
      {
        "arabic": "عَنۡ اَمۡرِنَا",
        "urdu": "ہمارے حکم سے"
      },
      {
        "arabic": "نُذِقۡہُ",
        "urdu": "ہم چکھاتے اسے"
      },
      {
        "arabic": "مِنۡ عَذَابِ",
        "urdu": "عذاب سے"
      },
      {
        "arabic": "السَّعِیۡرِ",
        "urdu": "بھڑکتی ہوئی آگ کے"
      }
    ]
  },
