      {
        "arabic": "وَکَانُوۡا",
        "urdu": "اور تھے وہ"
      },
      {
        "arabic": "لَنَا",
        "urdu": "ہماری ہی لیے"
      },
      {
        "arabic": "خٰشِعِیۡنَ",
        "urdu": "خشوع کرنے والے"
      }
