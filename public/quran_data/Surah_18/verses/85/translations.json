[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "وہ ایک راہ کے پیچھے لگا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "تو اس نے ایک (مہم کا) سروسامان کیا"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "چناچہ وہ ایک راہ (مہم) پر چل کھڑا ہوا"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "تو اس نے (سفر کا) ایک سامان کیا"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "تو وہ کچھ سامان ساتھ لے کر چلا۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "چنانچہ ذوالقرنین کچھ سامان لے کرچلا۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "پس وہ ایک مرتبہ وسائل کے درپے ہوا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "۔ پس وہ درپے ہوا اسباب و وسائل کے۔"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "پھر اس نے  ( ایک مہم کیلئے )  ساز و سامان کیا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "پھر انہوں نے ان وسائل کو استعمال کیا"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "اس نے ﴿پہلے مغرب کی طرف ایک مہم کا﴾ سروسامان کیا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پھر وہ ایک راہ  ( سفر )  پر روانہ ہوگیا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "جس کے نتیجے میں وہ ایک راستے کے پیچھے چل پڑے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "تو اس نے سفر کا ایک سامان کیا۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "چنانچہ وہ ایک راہ پر سامان لے کرچل کھڑا ہوا"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "تو وہ ایک سامان کے پیچھے چلا  ( ف۱۸۲ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "پس وہ  ( مزید )  اسباب کے پیچھے چل پڑا"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
