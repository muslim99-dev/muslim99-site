  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "پھروہ سامان لے کرایک اور راہ پر چل پڑا"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
