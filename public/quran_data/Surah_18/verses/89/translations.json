  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پھر وہ ایک  ( دوسری )  راہ  ( سفر )  پر روانہ ہوگیا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
