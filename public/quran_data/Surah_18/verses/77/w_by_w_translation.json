    "words": [
      {
        "arabic": "فَانۡطَلَقَا",
        "urdu": "پس وہ دونوں چل دیئے"
      },
      {
        "arabic": "حَتّٰۤی",
        "urdu": "یہاں تک کہ"
      },
      {
        "arabic": "اِذَاۤ",
        "urdu": "جب"
      },
      {
        "arabic": "اَتَیَاۤ",
        "urdu": "وہ دونوں آئے"
      },
      {
        "arabic": "اَہۡلَ قَرۡیَۃِۣ",
        "urdu": "ایک بستی والوں کے پاس"
      },
      {
        "arabic": "اسۡتَطۡعَمَاۤ",
        "urdu": "تو ان دونوں نے کھانا مانگا"
      },
      {
        "arabic": "اَہۡلَہَا",
        "urdu": "اس کے رہنے والوں سے"
      },
      {
        "arabic": "فَاَبَوۡا",
        "urdu": "تو انہوں نے انکار کردیا"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "کہ"
      },
      {
        "arabic": "یُّضَیِّفُوۡہُمَا",
        "urdu": "وہ مہمان بنائیں انہیں"
      },
      {
        "arabic": "فَوَجَدَا",
        "urdu": "تو ان دونوں نے پائی"
      },
      {
        "arabic": "فِیۡہَا",
        "urdu": "اس میں"
      },
      {
        "arabic": "جِدَارًا",
        "urdu": "ایک دیوار"
      },
      {
        "arabic": "یُّرِیۡدُ",
        "urdu": "وہ چاہتی تھی"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "کہ"
      },
      {
        "arabic": "یَّنۡقَضَّ",
        "urdu": "وہ ٹوٹ گرے"
      },
      {
        "arabic": "فَاَقَامَہٗ",
        "urdu": "تو اس نے سیدھا کھڑا کر دیا اسے"
      },
      {
        "arabic": "قَالَ",
        "urdu": "اس نے کہا"
      },
      {
        "arabic": "لَوۡ",
        "urdu": "اگر"
      },
      {
        "arabic": "شِئۡتَ",
        "urdu": "چاہتے تم"
      },
      {
        "arabic": "لَتَّخَذۡتَ",
        "urdu": "البتہ تو لے لیتا"
      },
      {
        "arabic": "عَلَیۡہِ",
        "urdu": "اس پر"
      },
      {
        "arabic": "اَجۡرًا",
        "urdu": "کوئی اجرت"
      }
    ]
  },
