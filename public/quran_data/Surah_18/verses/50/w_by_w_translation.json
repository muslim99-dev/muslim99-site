      },
      {
        "arabic": "لِلۡمَلٰٓئِکَۃِ",
        "urdu": "فرشتوں سے"
      },
      {
        "arabic": "اسۡجُدُوۡا",
        "urdu": "سجدہ کرو"
      },
      {
        "arabic": "لِاٰدَمَ",
        "urdu": "آدم کو"
      },
      {
        "arabic": "فَسَجَدُوۡۤا",
