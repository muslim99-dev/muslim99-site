  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "پھروہ ایک اور راہ پر سامان لے کرچل پڑا"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
