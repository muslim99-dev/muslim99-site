[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "بے سند باتیں کرنے والے غارت کر دیئے گئے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "ہلاک ہوجائیں یہ اٹکلیں دوڑانے والے۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "وہم و قیاس کرنے والوں کا ستیاناس ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "اٹکل دوڑانے والے ہلاک ہوں"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "اٹکل لگا نے والے مارے گئے۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "مارے گئے بے دلیل بات کرنے والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "اٹکل کے تیر تکے چلانے والے ہلاک ہوں!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "مارے گئے قیاس و گمان سے حکم لگانے والے"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "غارت ہوں اٹکل پچو باتیں بنانے والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "بیشک اٹکل پچو لگانے والے مارے جائیں گے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "مارے گئے قیاس و گمان سے حکم لگانے والے 8 ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "اٹکلیں دوڑانے والے ہلاک ہوجائیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "خدا کی مار ہو ان پر جو  ( عقیدے کے معاملے میں )  اٹکل پیچوں باتیں بنایا کرتے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "اٹکل دوڑانے والے ہلاک ہوں"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "بے سندباتیں کرنے والے غارت کردیئے گئے"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "مارے جایں دل سے تراشنے والے"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "ظنّ و تخمین سے جھوٹ بولنے والے ہلاک ہو گئے"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "मारे जाएँ अटकल दौड़ाने वाले;"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Destroyed are the falsifiers"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Destroyed are the falsifiers"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "Doomed are the conjecturers"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Cursed be Al-Kharrasun"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Accursed be the conjecturers"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "Death to those whose opinions are merely baseless conjectures."
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Cursed be the liars,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Woe to the falsehood-mongers,-"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "Death upon those who make conjectures (against the true faith),"
  }
]