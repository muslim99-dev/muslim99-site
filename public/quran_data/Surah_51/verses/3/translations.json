[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "پھر چلنے والیاں نرمی سے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "پھر نرمی سے چلنے والی ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "پھر ان کی جو آہستہ آہستہ چلتی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "پھر آہستہ آہستہ چلتی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "پھر آسانی سے چلنے والی ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "پھرجوآسانی سے چلنے والی ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "پھر چلنے لگتی ہیں آہستہ"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "پھر سبک رفتاری سے چلنے والی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "پھر ان  ( کشتیوں )  کی جو دھیمی رفتار سے چلنے والی ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "پھر دھیرے دھیرے چلنے والی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "پھر سبک رفتاری کے ساتھ چلنے والی ہیں ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پھر ان  ( ہواؤں )  کی قسم جو آہستہ آہستہ  ( سبک روئی سے )  چلتی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "پھر ان کی جو آسانی سے رواں دواں ہوجاتی ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "پھر آہستہ آہستہ چلتی ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "ان کشتیوں کی قسم جو سمندرمیں آرام کیساتھ چلتی رہتی ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "پھر نرم چلنے والیاں  ( ف٤ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "اور خراماں خراماں چلنے والی کشتیوں کی قَسم"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "फिर नरमी से चलती हैं;"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "And those [ships] sailing with ease"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "And those [ships] sailing with ease"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "which then smoothly speed along,"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "And the steady Jariyat;"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "And those that glide with ease (upon the sea)"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "by the ships which smoothly sail on the oceans,"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Then those (ships) that glide easily,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "And those that flow with ease and gentleness;"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "then those that float with ease,"
  }
]