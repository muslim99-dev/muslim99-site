[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "پس اس وقت گرد و غبار اڑاتے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "پھر وہ اس سے گرد اڑاتے ہوئے جاتے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "پھر ان کی جو غبار اڑاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "پھر اس میں گرد اٹھاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "پھر اس کے ساتھ غبار اڑاتے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "پھر اس کے ساتھ وہ غبار اُڑاتے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "دوڑ سے غبار اٹھانے والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "پھر اس موقع پر گردوغبار اڑاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "تو اس طرح گَرد و غبار اڑاتے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "پھر غبار جنگ اڑانے والے نہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "پھر اس موقع پر گردوغبار اڑاتے ہیں ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پس اس کی وجہ سے  ( ہر طرف )  گرد و غبار اُڑاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "پھر اس موقع پر غبار اڑاتے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "پھر اس میں گردا ٹھاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "پھر جو غبار اڑاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ٤ )  پھر اس وقت غبار اڑاتے ہیں ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "پھر وہ اس  ( حملے والی )  جگہ سے گرد و غبار اڑاتے ہیں"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "उस में उठाया उन्होंने गर्द-गुबार"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Stirring up thereby [clouds of] dust,"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Stirring up thereby [clouds of] dust,"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "and blaze a trail of dust,"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "And raise the dust in clouds the while."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Then, therewith, with their trail of dust,"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "and leave behind a cloud of dust"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Then thereby raise dust,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "And raise the dust in clouds the while,"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "then raise, at the same time, a trail of dust,"
  }
]