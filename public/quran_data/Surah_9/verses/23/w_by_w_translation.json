      },
      {
        "arabic": "اِنِ",
        "urdu": "اگر"
      },
      {
        "arabic": "اسۡتَحَبُّوا",
        "urdu": "وہ ترجیح دیں"
      },
      {
        "arabic": "الۡکُفۡرَ",
        "urdu": "کفر کو"
      },
      {
        "arabic": "عَلَی الۡاِیۡمَانِ",
        "urdu": "ایمان پر"
      },
      {
        "arabic": "وَمَنۡ",
        "urdu": "اور جو کوئی"
      },
      {
        "arabic": "یَّتَوَلَّہُمۡ",
        "urdu": "دوست رکھیےگا انہیں"
      },
      {
        "arabic": "مِّنۡکُمۡ",
        "urdu": "تم میں سے"
      },
      {
        "arabic": "فَاُولٰٓئِکَ",
        "urdu": "تو یہی لوگ ہیں"
      },
      {
        "arabic": "ہُمُ",
        "urdu": "وہ"
      },
      {
        "arabic": "الظّٰلِمُوۡنَ",
        "urdu": "جو ظالم ہیں"
      }
