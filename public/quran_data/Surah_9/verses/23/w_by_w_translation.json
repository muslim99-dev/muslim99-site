      {
        "arabic": "یٰۤاَیُّہَا الَّذِیۡنَ",
        "urdu": "اے لوگو! جو"
      },
      {
        "arabic": "اٰمَنُوۡا",
        "urdu": "ایمان لائے ہو"
      },
      {
        "arabic": "لَا تَتَّخِذُوۡۤا",
        "urdu": "نہ  تم بناؤ"
      },
      {
        "arabic": "اٰبَآءَکُمۡ",
        "urdu": "اپنے آباؤ اجداد کو"
      },
      {
        "arabic": "وَاِخۡوَانَکُمۡ",
