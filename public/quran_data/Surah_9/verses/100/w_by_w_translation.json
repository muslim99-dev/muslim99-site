    "words": [
      {
        "arabic": "وَالسّٰبِقُوۡنَ",
        "urdu": "اور سبقت کرنے والے"
      },
      {
        "arabic": "الۡاَوَّلُوۡنَ",
        "urdu": "سب سے  پہلے"
      },
      {
        "arabic": "مِنَ الۡمُہٰجِرِیۡنَ",
        "urdu": "مہاجرین میں سے"
      },
      {
        "arabic": "وَالۡاَنۡصَارِ",
        "urdu": "اور انصار میں سے"
      },
      {
        "arabic": "وَالَّذِیۡنَ",
        "urdu": "اور وہ جنہوں نے"
      },
      {
        "arabic": "اتَّبَعُوۡہُمۡ",
        "urdu": "پیروی کی ان کی"
      },
      {
        "arabic": "بِاِحۡسَانٍ",
        "urdu": "ساتھ احسان کے"
      },
      {
        "arabic": "رَّضِیَ",
        "urdu": "راضی ہوگیا"
      },
      {
        "arabic": "اللّٰہُ",
        "urdu": "اللہ"
      },
      {
        "arabic": "عَنۡہُمۡ",
        "urdu": "ان سے"
      },
      {
        "arabic": "وَرَضُوۡا",
        "urdu": "اور وہ راضی ہوگئے"
      },
      {
        "arabic": "عَنۡہُ",
        "urdu": "اس سے"
      },
      {
        "arabic": "وَاَعَدَّ",
        "urdu": "اور اس نے تیار کر راکھا ہے"
      },
      {
        "arabic": "لَہُمۡ",
        "urdu": "ان کے لیے"
      },
      {
        "arabic": "جَنّٰتٍ",
        "urdu": "باغات کو"
      },
      {
        "arabic": "تَجۡرِیۡ",
        "urdu": "بہتی ہیں"
      },
      {
        "arabic": "تَحۡتَہَا",
        "urdu": "نیچے  ان کے"
      },
      {
        "arabic": "الۡاَنۡہٰرُ",
        "urdu": "نہریں"
      },
      {
        "arabic": "خٰلِدِیۡنَ",
        "urdu": "ہمیشہ رہنے والے ہیں"
      },
      {
        "arabic": "فِیۡہَاۤ",
        "urdu": "اس میں"
      },
      {
        "arabic": "اَبَدًا",
        "urdu": "ہمیشہ ہمیشہ"
      },
      {
        "arabic": "ذٰلِکَ",
        "urdu": "یہی ہے"
      },
      {
        "arabic": "الۡفَوۡزُ",
        "urdu": "کامیابی"
      },
      {
        "arabic": "الۡعَظِیۡمُ",
        "urdu": "بہت بڑی"
      }
    ]
  },
