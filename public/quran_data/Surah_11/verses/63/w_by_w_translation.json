[
  {
    "translator": "Dr Farhat Hashmi",
    "words": [
      {
        "arabic": "قَالَ",
        "urdu": "اس نے کہا"
      },
      {
        "arabic": "یٰقَوۡمِ",
        "urdu": "اے میری قوم"
      },
      {
        "arabic": "اَرَءَیۡتُمۡ",
        "urdu": "کیا دیکھا تم نے"
      },
      {
        "arabic": "اِنۡ",
        "urdu": "اگر"
      },
      {
        "arabic": "کُنۡتُ",
        "urdu": "ہوں میں"
      },
      {
        "arabic": "عَلٰی بَیِّنَۃٍ",
        "urdu": "ایک واضح دلیل پر"
      },
      {
        "arabic": "مِّنۡ رَّبِّیۡ",
        "urdu": "اپنے رب کی طرف سے"
      },
      {
        "arabic": "وَاٰتٰىنِیۡ",
        "urdu": "اور اس نے دی ہو مجھے"
      },
      {
        "arabic": "مِنۡہُ",
        "urdu": "اپنی طرف سے"
      },
      {
        "arabic": "رَحۡمَۃً",
        "urdu": "رحمت"
      },
      {
        "arabic": "فَمَنۡ",
        "urdu": "تو کون"
      },
      {
        "arabic": "یَّنۡصُرُنِیۡ",
        "urdu": "مدد کرے گا میری"
      },
      {
        "arabic": "مِنَ اللّٰہِ",
        "urdu": "اللہ سے (بچانے میں)"
      },
      {
        "arabic": "اِنۡ",
        "urdu": "اگر"
      },
      {
        "arabic": "عَصَیۡتُہٗ",
        "urdu": "نافرمانی کی میں نے اس کی"
      },
      {
        "arabic": "فَمَا",
        "urdu": "تو نہیں"
      },
      {
        "arabic": "تَزِیۡدُوۡنَنِیۡ",
        "urdu": "تم زیادھ کرو گے مجھے"
      },
      {
        "arabic": "غَیۡرَ",
        "urdu": "سوائے"
      },
      {
        "arabic": "تَخۡسِیۡرٍ",
        "urdu": "سوائے خسارہ دینے کے"
      }
    ]
  },
