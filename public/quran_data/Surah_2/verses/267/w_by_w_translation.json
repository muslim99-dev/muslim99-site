  {
    "translator": "Dr Farhat Hashmi",
    "words": [
      {
        "arabic": "یٰۤاَیُّہَا الَّذِیۡنَ",
        "urdu": "اے لوگو جو"
      },
      {
        "arabic": "اٰمَنُوۡۤا",
        "urdu": "ایمان لائے ہو"
      },
      {
        "arabic": "اَنۡفِقُوۡا",
        "urdu": "خرچ کرو"
      },
      {
        "arabic": "مِنۡ طَیِّبٰتِ",
        "urdu": "پاکیزہ چیزوں میں سے"
      },
      {
        "arabic": "مَا",
        "urdu": "جو"
      },
      {
        "arabic": "کَسَبۡتُمۡ",
        "urdu": "تم کمائیں تم نے"
      },
      {
        "arabic": "وَمِمَّاۤ",
        "urdu": "اور  اس میں سے جو"
      },
      {
        "arabic": "اَخۡرَجۡنَا",
        "urdu": "نکالا ہم نے"
      },
      {
        "arabic": "لَکُمۡ",
        "urdu": "تمہارے لیے"
      },
      {
        "arabic": "مِّنَ الۡاَرۡضِ",
        "urdu": "زمین سے"
      },
      {
        "arabic": "وَلَا",
        "urdu": "اور نہ"
      },
      {
        "arabic": "تَیَمَّمُوا",
        "urdu": "تم ارادہ کرو"
      },
      {
        "arabic": "الۡخَبِیۡثَ",
        "urdu": "ناپاک کا"
      },
      {
        "arabic": "مِنۡہُ",
        "urdu": "اس میں سے جو"
      },
      {
        "arabic": "تُنۡفِقُوۡنَ",
        "urdu": "تم خرچ کرتے ہو"
      },
      {
        "arabic": "وَلَسۡتُمۡ",
        "urdu": "حالانکہ نہیں تم"
      },
      {
        "arabic": "بِاٰخِذِیۡہِ",
        "urdu": "لینے والے اسے"
      },
      {
        "arabic": "اِلَّاۤ",
        "urdu": "مگر"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "یہ کہ"
      },
      {
        "arabic": "تُغۡمِضُوۡا",
        "urdu": "تم چشم پوشی کرو"
      },
      {
        "arabic": "فِیۡہِ",
        "urdu": "اس میں"
      },
      {
        "arabic": "وَاعۡلَمُوۡۤا",
        "urdu": "اور  جان لو"
      },
      {
        "arabic": "اَنَّ",
        "urdu": "بےشک"
      },
      {
        "arabic": "اللّٰہَ",
        "urdu": "اللہ تعالی"
      },
      {
        "arabic": "غَنِیٌّ",
        "urdu": "بہت بےنیاز ہے"
      },
      {
        "arabic": "حَمِیۡدٌ",
        "urdu": "بہت تعریف والا ہے"
      }
    ]
  },
