      {
        "arabic": "یَسۡئَلُوۡنَکَ",
        "urdu": "وہ سوال کرتے ہیں آپ سے"
      },
      {
        "arabic": "مَاذَا",
        "urdu": "کیا کچھ"
      },
      {
        "arabic": "یُنۡفِقُوۡنَ",
        "urdu": "وہ خرچ کریں"
      },
      {
        "arabic": "قُلۡ",
        "urdu": "کہہ دیجیے"
      },
      {
        "arabic": "مَاۤ",
        "urdu": "جو"
      },
      {
        "arabic": "اَنۡفَقۡتُمۡ",
        "urdu": "خرچ کرو تم"
      },
      {
        "arabic": "مِّنۡ خَیۡرٍ",
