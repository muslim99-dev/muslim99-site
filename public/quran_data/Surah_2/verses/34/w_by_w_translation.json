        "arabic": "فَسَجَدُوۡۤا",
        "urdu": "تو انہوں نے سجدہ کیا"
      },
      {
        "arabic": "اِلَّاۤ",
        "urdu": "سوائے"
      },
      {
        "arabic": "اِبۡلِیۡسَ",
