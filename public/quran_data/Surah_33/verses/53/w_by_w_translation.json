    "words": [
      {
        "arabic": "یٰۤاَیُّہَا الَّذِیۡنَ",
        "urdu": "اے لوگو جو"
      },
      {
        "arabic": "اٰمَنُوۡا",
        "urdu": "ایمان لائے ہو"
      },
      {
        "arabic": "لَاتَدۡخُلُوۡا",
        "urdu": "نہ تم داخل ہو"
      },
      {
        "arabic": "بُیُوۡتَ",
        "urdu": "گھروں میں"
      },
      {
        "arabic": "النَّبِیِّ",
        "urdu": "نبی کے"
      },
      {
        "arabic": "اِلَّاۤ",
        "urdu": "مگر"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "یہ کہ"
      },
      {
        "arabic": "یُّؤۡذَنَ",
        "urdu": "اجازت دی جائے"
      },
      {
        "arabic": "لَکُمۡ",
        "urdu": "تمہیں"
      },
      {
        "arabic": "اِلٰی طَعَامٍ",
        "urdu": "طرف کھانے کے"
      },
      {
        "arabic": "غَیۡرَ",
        "urdu": "نہ"
      },
      {
        "arabic": "نٰظِرِیۡنَ",
        "urdu": "انتظار کرنے والے ہو"
      },
      {
        "arabic": "اِنٰىہُ",
        "urdu": "اس کی تیاری کا"
      },
      {
        "arabic": "وَلٰکِنۡ",
        "urdu": "اور لیکن"
      },
      {
        "arabic": "اِذَا",
        "urdu": "جب"
      },
      {
        "arabic": "دُعِیۡتُمۡ",
        "urdu": "بلائے جاؤ تم"
      },
      {
        "arabic": "فَادۡخُلُوۡا",
        "urdu": "تو داخل ہوجاؤ"
      },
      {
        "arabic": "فَاِذَا",
        "urdu": "پھر جب"
      },
      {
        "arabic": "طَعِمۡتُمۡ",
        "urdu": "کھانا کھا لو تم"
      },
      {
        "arabic": "فَانۡتَشِرُوۡا",
        "urdu": "تو منتشر ہوجاؤ"
      },
      {
        "arabic": "وَلَا",
        "urdu": "اور نہ ہو"
      },
      {
        "arabic": "مُسۡتَاۡنِسِیۡنَ",
        "urdu": "دل لگانے والے"
      },
      {
        "arabic": "لِحَدِیۡثٍ",
        "urdu": "باتوں کے لیے"
      },
      {
        "arabic": "اِنَّ",
        "urdu": "بےشک"
      },
      {
        "arabic": "ذٰلِکُمۡ",
        "urdu": "یہ"
      },
      {
        "arabic": "کَانَ",
        "urdu": "ہے"
      },
      {
