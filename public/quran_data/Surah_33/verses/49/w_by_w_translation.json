    "translator": "Dr Farhat Hashmi",
    "words": [
      {
        "arabic": "یٰۤاَیُّہَا الَّذِیۡنَ",
        "urdu": "اے لوگو جو"
      },
      {
        "arabic": "اٰمَنُوۡۤا",
        "urdu": "ایمان لائے ہو"
      },
      {
        "arabic": "اِذَا",
        "urdu": "جب"
      },
      {
        "arabic": "نَکَحۡتُمُ",
        "urdu": "نکاح کرو تم"
      },
      {
        "arabic": "الۡمُؤۡمِنٰتِ",
        "urdu": "مومن عورتوں سے"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "طَلَّقۡتُمُوۡہُنَّ",
        "urdu": "طلاق دے دو تم انہیں"
      },
      {
        "arabic": "مِنۡ قَبۡلِ",
        "urdu": "اس سے پہلے"
      },
      {
        "arabic": "اَنۡ",
        "urdu": "کہ"
      },
      {
        "arabic": "تَمَسُّوۡہُنَّ",
        "urdu": "تم چھوؤ انہیں"
      },
      {
        "arabic": "فَمَا",
        "urdu": "تو نہیں"
      },
      {
        "arabic": "لَکُمۡ",
        "urdu": "تمہارے لیے"
      },
      {
        "arabic": "عَلَیۡہِنَّ",
        "urdu": "ان پر"
      },
      {
        "arabic": "مِنۡ عِدَّۃٍ",
        "urdu": "کوئی عدت"
      },
      {
        "arabic": "تَعۡتَدُّوۡنَہَا",
        "urdu": "کہ تم شمار کرو اسے"
      },
      {
        "arabic": "فَمَتِّعُوۡہُنَّ",
        "urdu": "تو کچھ فائدہ دو انہیں"
      },
      {
        "arabic": "وَسَرِّحُوۡہُنَّ",
        "urdu": "اور رخصت کرو انہیں"
      },
      {
        "arabic": "سَرَاحًا",
        "urdu": "رخصت کرنا"
      },
      {
        "arabic": "جَمِیۡلًا",
        "urdu": "بھلے طریقے سے"
      }
    ]
  },
