[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "۔   ( کہ )  خندقوں والے ہلاک کئے گئے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "ہلاک ہوگئے وہ کھائیوں والے۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "کہ خندقوں والے ہلاک ہوگئے"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "کہ خندقوں (کے کھودنے) والے ہلاک کر دیئے گئے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "مارے گئے اس خندق والے۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "مارے گئے خندقوں والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "ہلاک ہوئے گھاٹی والے"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "مارے گئے ایندھن بھری"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "غارت ہوئے خندق والے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "اصحاب اخدود ہلاک کردیئے گئے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "کہ مارے گئے گڑھے والے ،  ﴿اس گڑھے والے﴾"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "بڑی بڑی خندقوں والے ہلاک کردیے گئے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "کہ خدا کی مار ہے ان خندق  ( کھودنے )  والوں پر  ( ٣ )"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "کہ خندقوں کے کھودنے والے ہلاک کردئیے گئے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "کہ خندقوں والے ہلاک ہوگئے"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ٤ )  کھائی والوں پر لعنت ہو  ( ف٦ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "خندقوں والے  ( لوگ )  ہلاک کر دیے گئے"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "विनष्ट हों खाई वाले,"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Cursed were the companions of the trench"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Cursed were the companions of the trench"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "the people of the pit were destroyed"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Cursed were the People of the Ditch."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "(Self-)destroyed were the owners of the ditch"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "may the people be condemned those who tortured (the believers) in ditches"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Cursed be the makers of the pit,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Woe to the makers of the pit (of fire),"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "cursed were the People of the Trench,"
  }
]