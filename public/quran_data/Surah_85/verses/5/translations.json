[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "وہ ایک آگ تھی ایندھن والی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "وہ آگ جو بڑی ایندھن والی تھی۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "جن میں آگ تھی بہت ایندھن والی"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "(یعنی) آگ (کی خندقیں) جس میں ایندھن (جھونک رکھا) تھا"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "جو سرا سر آگ تھی بہت ایندھن والی۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "آگ تھی بہت ایندھن والی۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "ایندھن بھری آگ کی!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "آگ کی گھاٹی والے۔"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "جس میں بھڑکتے ہوئے ایندھن والی آگ تھی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "آگ سے بھری ہوئی خندقوں والے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "جس میں خوب بھڑکتے ہوئے ایندھن کی آگ تھی  ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "ایندھن والی آگ  ( جس میں بھری ہوئی تھی )"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "اس آگ والوں پر جو ایندھن سے بھری ہوئی تھی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "یعنی آگ کی خندقیں جن میں ایندھن جھونک رکھا تھا"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "وہ ایک آگ تھی ایندھن والی"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ۵ )  اس بھڑکتی آگ والے ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "۔   ( یعنی )  اس بھڑکتی آگ  ( والے )  جو بڑے ایندھن سے  ( جلائی گئی )  تھی"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "ईंधन भरी आग वाले,"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "[Containing] the fire full of fuel,"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "[Containing] the fire full of fuel,"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "with fire abounding in fuel,"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Of fire fed with fuel."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Of the fuel-fed fire,"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "by a burning fire"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Of the fire (kept burning) with fuel,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Fire supplied (abundantly) with fuel:"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "the (people of the) fire that was rich with fuel,"
  }
]