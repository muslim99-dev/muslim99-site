[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "پھر چلنے پھرنے والے چھپنے والے ستاروں کی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "اور چھپ جانے والے ستاروں کی۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "جو سیدھے چلتے چلتے غائب ہوجاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "(اور) جو سیر کرتے اور غائب ہو جاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "جو چلنے والے ہیں، چھپ جانے والے ہیں !"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "جوچلتے رہنے والے،چھپ جانے والے ہیں۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "جلنے والے اور چھپ جانے والے  ( ستاروں )  کی!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "سیدھے چلنے والوں اور چھپ جانے والے ستاروں کی"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "سیدھے چلنے اور چھپ جانے والے ستاروں کی ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "چلنے والے اورحُھپ جانے والے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "اور چھپ جانے والے تاروں کی  ،"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "اور سیر کرنے والے  ( اور )  چھپ جانے والے ہیں ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "جو چلتے چلتے دبک جاتے ہیں ۔   ( ٧ )"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "اور جو سیر کرتے اور غائب ہوجاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "جوسیدھے چلتے چلتے غائب ہو جاتے ہیں"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ۱٦ )  سیدھے چلیں تھم رہیں  ( ف۱۷ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "جو بلا روک ٹوک چلتے رہتے ہیں  ( پھر ظاہر ہو کر )  چھپ جاتے ہیں"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "चलने वालों, छिपने-दुबकने-वालों की"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Those that run [their courses] and disappear -"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Those that run [their courses] and disappear -"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "that hide,"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Al-Jawar Al-Kunnas."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "The stars which rise and set,"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "stars which are visible during the night"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "That run their course (and) hide themselves,"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Go straight, or hide;"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "that proceed, that withdraw from the scene,"
  }
]