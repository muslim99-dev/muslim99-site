      {
        "arabic": "الَّذِیۡ",
        "urdu": "وہی ہے جس نے"
      },
      {
        "arabic": "خَلَقَکُمۡ",
        "urdu": "پیدا کیا تمہیں"
      },
      {
        "arabic": "مِّنۡ تُرَابٍ",
        "urdu": "مٹی سے"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "مِنۡ نُّطۡفَۃٍ",
        "urdu": "نطفے سے"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "مِنۡ عَلَقَۃٍ",
        "urdu": "جمے ہوئے خون سے"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "یُخۡرِجُکُمۡ",
        "urdu": "وہ نکالتا ہے تمہیں"
      },
      {
        "arabic": "طِفۡلًا",
        "urdu": "بچہ(بنا کر)"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "لِتَبۡلُغُوۡۤا",
        "urdu": "تا کہ تم پہنچ جاؤ"
      },
      {
        "arabic": "اَشُدَّکُمۡ",
        "urdu": "اپنی جوانی کو"
      },
      {
        "arabic": "ثُمَّ",
        "urdu": "پھر"
      },
      {
        "arabic": "لِتَکُوۡنُوۡا",
        "urdu": "تا کہ تم ہو جاؤ"
      },
      {
        "arabic": "شُیُوۡخًا",
        "urdu": "بوڑھے"
      },
      {
        "arabic": "وَمِنۡکُمۡ",
        "urdu": "اور تم میں سے"
      },
      {
        "arabic": "مَّنۡ",
        "urdu": "کوئی ہے جو"
      },
      {
        "arabic": "یُّتَوَفّٰی",
        "urdu": "فوت کر دیا جاتا ہے"
      },
      {
        "arabic": "مِنۡ قَبۡلُ",
        "urdu": "اس سے پہلے"
      },
      {
        "arabic": "وَلِتَبۡلُغُوۡۤا",
        "urdu": "اور تاکہ تم پہنچو"
      },
      {
        "arabic": "اَجَلًا",
        "urdu": "ایک وقت کو"
      },
      {
        "arabic": "مُّسَمًّی",
        "urdu": "مقرر"
      },
      {
        "arabic": "وَّلَعَلَّکُمۡ",
        "urdu": "اور تاکہ تم"
      },
      {
        "arabic": "تَعۡقِلُوۡنَ",
        "urdu": "تم عقل سے کام لو"
      }
    ]
