  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "پھر افسوس ہے تجھ پر پھر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "پھر تیرے لائق یہی ہے، پھر یہی لائق ہے۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "پھر تیرے لیے یہی لائق ہے، پھریہی لائق ہے۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "پھر افسوس ہے تجھ پر! افسوس ہے!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "پھر افسوس ہے تجھ پر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "پھر یہ تیرے ہی لائق ہے اور تیرے ہی لئے سزوار ہے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "حیف ہے اور صد حیف ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "ہاں یہ روش تیرے ہی لیے سزاوار ہے اور تجھی کو زیب دیتی ہے22 ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "پھر تیرے لیے ہلاکت در ہلاکت ہو"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "پھر سن لے کہ بربادی ہے تیری ،  ہاں بربادی ہے تیری  !  ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "پھر افسوس ہے تجھ پر پھر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "پھرافسوس ہے تجھ پر"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "پھر تیری خرابی آ لگی اب آ لگی  ،   ( ف۳٤ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "پھر تمہارے لئے  ( روزِ قیامت )  ہلاکت ہے ،  پھر  ( دوزخ کی )  ہلاکت ہے"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "फिर अफ़सोस है तुझ पर और अफ़सोस है!"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Then woe to you, and woe!"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Then woe to you, and woe!"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "again, it is worthy of you, altogether worthy."
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Again, woe to you! And then woe to you!"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Again nearer unto thee and nearer (is the doom)."
  },
  {
    "language": "English",
