  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "تیرے لیے ہلاکت در ہلاکت ہو"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "بربادی ہے تیری ،  ہاں بربادی ہے تیری  !  ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "افسوس ہے تجھ پر پھر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "افسوس ہے تجھ پر"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "تیری خرابی آ لگی اب آ لگی  ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "تمہارے لئے  ( مرتے وقت )  تباہی ہے ،  پھر  ( قبر میں )  تباہی ہے"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "अफ़सोस है तुझ पर और अफ़सोस है!"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Woe to you, and woe!"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Woe to you, and woe!"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "This (attitude) is worthy of you, altogether worthy;"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Woe to you! And then woe to you!"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Nearer unto thee and nearer,"
  },
  {
    "language": "English",
