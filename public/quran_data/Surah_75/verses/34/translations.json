  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "افسوس ہے تجھ پر! افسوس ہے!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "افسوس ہے تجھ پر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "یہ  ( روش )  تیرے ہی لئے سزاوار ہے اور تیرے ہی لائق ہے ۔"
  },
  {
    "language": "Urdu",
