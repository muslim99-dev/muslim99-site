  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "And repulse not the one who asks."
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Therefor the beggar drive not away,"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "and do not reject the beggars"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "And as for him who asks, do not chide (him),"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Nor repulse the petitioner (unheard);"
  },
  {
    "language": "English",
