      {
        "arabic": "وَمِنۡ اٰیٰتِہٖ",
        "urdu": "اور اس کی نشانیوں میں سے ہے"
      },
      {
        "arabic": "مَنَامُکُمۡ",
        "urdu": "سونا تمہارا"
      },
      {
        "arabic": "بِالَّیۡلِ",
        "urdu": "رات"
      },
      {
        "arabic": "وَالنَّہَارِ",
        "urdu": "اور دن کو"
      },
      {
        "arabic": "وَابۡتِغَآؤُکُمۡ",
        "urdu": "اور تلاش کرنا تمہارا"
      },
      {
        "arabic": "مِّنۡ فَضۡلِہٖ",
        "urdu": "اس کے فضل سے"
      },
      {
        "arabic": "اِنَّ",
        "urdu": "یقیناً"
      },
      {
        "arabic": "فِیۡ ذٰلِکَ",
        "urdu": "اس میں"
      },
      {
        "arabic": "لَاٰیٰتٍ",
        "urdu": "البتہ نشانیاں ہیں"
      },
      {
        "arabic": "لِّقَوۡمٍ",
        "urdu": "ان لوگوں کے لیے"
      },
      {
        "arabic": "یَّسۡمَعُوۡنَ",
        "urdu": "جو سنتے ہیں"
      }
    ]
