      },
      {
        "arabic": "وَبَدَا",
        "urdu": "اور ظاہر ہو جائے گا"
      },
      {
        "arabic": "لَہُمۡ",
        "urdu": "ان کے لیے"
      },
      {
        "arabic": "مِّنَ اللّٰہِ",
        "urdu": "اللہ کی طرف سے"
      },
      {
        "arabic": "مَا",
        "urdu": "جو"
      },
      {
        "arabic": "لَمۡ",
        "urdu": "نہ"
      },
      {
        "arabic": "یَکُوۡنُوۡا",
        "urdu": "تھے وہ"
      },
      {
        "arabic": "یَحۡتَسِبُوۡنَ",
        "urdu": "وہ گمان رکھتے"
      }
