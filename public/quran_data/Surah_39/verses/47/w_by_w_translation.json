      {
        "arabic": "اَنَّ",
        "urdu": "بےشک ہو"
      },
      {
        "arabic": "لِلَّذِیۡنَ",
        "urdu": "ان کے لیے جنہوں نے"
      },
      {
        "arabic": "ظَلَمُوۡا",
        "urdu": "ظلم کیا"
      },
      {
        "arabic": "مَا",
        "urdu": "جو کچھ"
      },
      {
        "arabic": "فِی الۡاَرۡضِ",
        "urdu": "زمین میں ہے"
      },
      {
        "arabic": "جَمِیۡعًا",
        "urdu": "سب کا سب"
      },
      {
        "arabic": "وَّ مِثۡلَہٗ",
        "urdu": "اور اس کی مانند"
      },
      {
