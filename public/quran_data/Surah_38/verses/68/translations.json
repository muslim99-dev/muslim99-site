[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "جس سے تم بے پروا ہو رہے ہو ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "تم اس سے اعراض کر رہے ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "جس سے تم اعراض کر رہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "جس کو تم دھیان میں نہیں لاتے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "جس سے تم منہ پھیر نے والے ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "جس سے تم منہ پھیرنے والے ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "تم اس سے اعراض کیے ہوئے ہو!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "اور تم اس سے اعراض کررہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "جس سے تم منہ پھیرتے ہو ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "تم اس سے اعراض کئے ہوئے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "جس کو سن کر تم منہ پھیرتے ہو   58 ۔"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "تم اس سے روگردانی کررہے ہو"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "جس سے تم منہ موڑے ہوئے ہو ۔   ( ٢٦ )"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "جس کو تم دھیان میں نہیں لاتے۔"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "جس سے تم نے منہ پھیر رکھا ہے"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "تم اس سے غفلت میں ہو  ( ف۹۰ )"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "تم اس سے منہ پھیرے ہوئے ہو"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "जिसे तुम ध्यान में नहीं ला रहे हो"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "From which you turn away."
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "From which you turn away."
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "from which you are turning away.”"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "\"From which you turn away!\""
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Whence ye turn away!"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "but you have turned away from it."
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "(And) you are turning aside from it:"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "\"From which ye do turn away!"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "to which you are averse."
  }
]