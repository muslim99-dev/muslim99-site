        "urdu": "بھلائی(کرنے)کی"
      },
      {
        "arabic": "وَاِنۡ",
        "urdu": "اور اگر"
      },
      {
        "arabic": "جَاہَدٰکَ",
        "urdu": "وہ دونوں زور ڈالیں تم پر"
      },
      {
        "arabic": "لِتُشۡرِکَ",
        "urdu": "تا کہ تم شریک کرو"
      },
      {
