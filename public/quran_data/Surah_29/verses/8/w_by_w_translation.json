        "arabic": "وَوَصَّیۡنَا",
        "urdu": "اور تاکید کی ہم نے"
      },
      {
        "arabic": "الۡاِنۡسَانَ",
        "urdu": "انسان کو"
      },
      {
        "arabic": "بِوَالِدَیۡہِ",
        "urdu": "اپنے والدین کے ساتھ"
