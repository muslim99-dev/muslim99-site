      },
      {
        "arabic": "غَیۡرِہٖ",
        "urdu": "سوائے اس کے"
      },
      {
        "arabic": "وَاِمَّا",
        "urdu": "اور اگر"
      },
      {
        "arabic": "یُنۡسِیَنَّکَ",
        "urdu": "بھلا دے آپ کو"
      },
      {
        "arabic": "الشَّیۡطٰنُ",
        "urdu": "شیطان"
      },
      {
        "arabic": "فَلَا",
        "urdu": "تو نہ"
      },
      {
        "arabic": "تَقۡعُدۡ",
        "urdu": "آپ بیٹھیے"
      },
      {
        "arabic": "بَعۡدَ",
