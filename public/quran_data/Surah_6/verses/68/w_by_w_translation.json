        "arabic": "رَاَیۡتَ",
        "urdu": "دیکھیں  آپ"
      },
      {
        "arabic": "الَّذِیۡنَ",
        "urdu": "ان لوگوں کو"
      },
      {
        "arabic": "یَخُوۡضُوۡنَ",
        "urdu": "جو مشغول ہوتے ہیں"
      },
      {
        "arabic": "فِیۡۤ اٰیٰتِنَا",
        "urdu": "ہماری آیات میں"
      },
      {
        "arabic": "فَاَعۡرِضۡ",
        "urdu": "تو اعراض کیجئے"
      },
      {
        "arabic": "عَنۡہُمۡ",
        "urdu": "ان سے"
      },
      {
        "arabic": "حَتّٰی",
        "urdu": "یہاں تک کہ"
      },
      {
        "arabic": "یَخُوۡضُوۡا",
