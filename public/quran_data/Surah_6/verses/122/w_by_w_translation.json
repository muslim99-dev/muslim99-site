    "words": [
      {
        "arabic": "اَوَمَنۡ",
        "urdu": "کیا بھلا جو"
      },
      {
        "arabic": "کَانَ",
        "urdu": "تھا"
      },
      {
        "arabic": "مَیۡتًا",
        "urdu": "مردہ"
      },
      {
        "arabic": "فَاَحۡیَیۡنٰہُ",
        "urdu": "تو زندہ کیا ہم نے اسے"
      },
      {
        "arabic": "وَجَعَلۡنَا",
        "urdu": "اور بنایا ہم نے"
      },
      {
        "arabic": "لَہٗ",
        "urdu": "اس کے لئے"
      },
      {
        "arabic": "نُوۡرًا",
        "urdu": "ایک نور"
      },
      {
        "arabic": "یَّمۡشِیۡ",
        "urdu": "وہ چلتاہے"
      },
      {
        "arabic": "بِہٖ",
        "urdu": "ساتھ اس کے"
      },
      {
        "arabic": "فِی النَّاسِ",
        "urdu": "لوگوں میں"
      },
      {
        "arabic": "کَمَنۡ مَّثَلُہٗ",
        "urdu": "اس کی طرح ہو سکتا ہے وہ"
      },
      {
        "arabic": "فِی الظُّلُمٰتِ",
        "urdu": "اندھیروں میں ہے"
      },
      {
        "arabic": "لَیۡسَ",
        "urdu": "نہیں ہے"
      },
      {
        "arabic": "بِخَارِجٍ",
        "urdu": "نکلنے والا"
      },
      {
        "arabic": "مِّنۡہَا",
        "urdu": "ان سے"
      },
      {
        "arabic": "کَذٰلِکَ",
        "urdu": "اسی طرح"
      },
      {
        "arabic": "زُیِّنَ",
        "urdu": "مزین کردیا گیا ہے"
      },
      {
        "arabic": "لِلۡکٰفِرِیۡنَ",
        "urdu": "کافروں کے لئے"
      },
      {
        "arabic": "مَا",
        "urdu": "جو"
      },
      {
        "arabic": "کَانُوۡا",
        "urdu": "ہیں وہ"
      },
      {
        "arabic": "یَعۡمَلُوۡنَ",
        "urdu": "وہ عمل کرتے"
      }
    ]
  },
