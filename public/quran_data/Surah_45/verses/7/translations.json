[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "ویل‘‘اور افسوس ہے ہر ایک جھوٹے گنہگار پر ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "بربادی ہے ہر جھوٹ گھڑنے والے گنہگار کے لیے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "تباہی ہے ہر اس بہتان تراش اور گنہگار کے لئے"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "ہر جھوٹے گنہگار پر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "بڑی ہلاکت ہے ہر سخت جھوٹے، گناہ گار کے لیے۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "ہرسخت جھوٹے گناہ گار کے لیے بڑی ہلاکت ہے۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "ہلاکی ہے اس لپاٹیے گنہگار کیلئے"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "تباہی ہے ہر اس جھوٹے بداعمال شخص کے لیے"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "ہلاکت ہے ہر اس بڑے جھوٹے  ( اور )  بڑے گنہگار کے لئے ۔"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "بیشک ہر جھوٹے گنہگار کے حال پر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "تباہی ہے ہر اس جھوٹے بد اعمال شخص کے لیے"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "اور ہر چھوٹے گنہگار کے لیے تباہی ہے"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "برا ہو اس جھوٹے گنہگار کا ۔"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "ہر جھوٹے گنہگار پر افسوس ہے"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "تباہی ہے ہرجھوٹے گنہگارکے لئے"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
