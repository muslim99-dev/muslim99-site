      {
        "arabic": "وَضَرَبَ",
        "urdu": "اور بیان کی"
      },
      {
        "arabic": "اللّٰہُ",
        "urdu": "اللہ تعالی نے"
      },
      {
        "arabic": "مَثَلًا",
        "urdu": "ایک مثال"
      },
      {
        "arabic": "رَّجُلَیۡنِ",
        "urdu": "دو مردوں کی"
      },
      {
        "arabic": "اَحَدُہُمَاۤ",
        "urdu": "ان دونوں میں سے ایک"
      },
      {
        "arabic": "اَبۡکَمُ",
        "urdu": "گونگا ہے"
      },
      {
        "arabic": "لَایَقۡدِرُ",
        "urdu": "نہیں وہ قدرت رکھتا"
      },
      {
        "arabic": "عَلٰی شَیۡءٍ",
        "urdu": "کسی چیز پر"
      },
      {
        "arabic": "وَّہُوَ",
        "urdu": "اور وہ"
      },
      {
        "arabic": "کَلٌّ",
        "urdu": "بوجھ ہے"
      },
      {
        "arabic": "عَلٰی مَوۡلٰىہُ",
        "urdu": "اپنے مالک پر"
      },
      {
        "arabic": "اَیۡنَمَا",
        "urdu": "جہاں کہیں"
      },
      {
        "arabic": "یُوَجِّہۡہُّ",
        "urdu": "وہ بھیجتا ہے اس ے"
      },
      {
        "arabic": "لَایَاۡتِ",
        "urdu": "نہیں وہ لاتا"
      },
      {
        "arabic": "بِخَیۡرٍ",
        "urdu": "کوئی بھلائی"
      },
      {
        "arabic": "ہَلۡ",
        "urdu": "کیا"
      },
      {
        "arabic": "یَسۡتَوِیۡ",
        "urdu": "برابر ہوسکتا ہے"
      },
      {
        "arabic": "ہُوَ",
        "urdu": "وہ"
      },
      {
        "arabic": "وَمَنۡ",
        "urdu": "اور وہ جو"
      },
      {
        "arabic": "یَّاۡمُرُ",
        "urdu": "حکم دیتا ہے"
      },
      {
        "arabic": "بِالۡعَدۡلِ",
        "urdu": "انصاف کا"
      },
      {
        "arabic": "وَہُوَ",
        "urdu": "اور وہ"
      },
      {
        "arabic": "عَلٰی صِرَاطٍ",
        "urdu": "اپر راستے"
      },
      {
        "arabic": "مُّسۡتَقِیۡمٍ",
        "urdu": "سیدھے  کے ہے"
      }
