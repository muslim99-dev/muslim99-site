[
  {
    "language": "Urdu",
    "translator": "Muhammad Junagarhi",
    "text": "یا پرہیزگاری کا حکم دیتا ہو ۔"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Israr Ahmad",
    "text": "یا وہ تقویٰ کی تعلیم دیتا !"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Rehman Killani",
    "text": "یا نافرمانی سے بچنے کا حکم دیتا ہو"
  },
  {
    "language": "Urdu",
    "translator": "Fateh Muhammad Jalandhari",
    "text": "یا پرہیز گاری کا حکم کرے (تو منع کرنا کیسا)"
  },
  {
    "language": "Urdu",
    "translator": "Abdul Salam Bhutvi",
    "text": "یا اس نے پرہیزگاری کا حکم دیا ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Ustaza Nighat Hashmi",
    "text": "تقویٰ کاحکم دیتا ہو۔"
  },
  {
    "language": "Urdu",
    "translator": "Amin Ahsan Islahi",
    "text": "یا نیکی کی تلقین کرنے والا ہو!"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Muhammad Aslam Siddiqui",
    "text": "یا نیکی کا حکم دینے والا ہوا"
  },
  {
    "language": "Urdu",
    "translator": "Hussain Najfi",
    "text": "یا وہ پرہیزگاری کا حکم دیتا ہے؟"
  },
  {
    "language": "Urdu",
    "translator": "Allama Jawadi",
    "text": "یا تقویٰ کا حکم دے تو روکنا کیسا ہے"
  },
  {
    "language": "Urdu",
    "translator": "Abul A'la Maudoodi",
    "text": "یا پرہیزگاری کی تلقین کرتا ہو؟"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Naeem",
    "text": "یا پرہیزگاری کا حکم کرتا ہو"
  },
  {
    "language": "Urdu",
    "translator": "Mufti Taqi Usmani",
    "text": "یا تقوی کا حکم دیتا ہو  ( تو کیا اسے روکنا گمراہی نہیں؟ )"
  },
  {
    "language": "Urdu",
    "translator": "Riffat Aijaz",
    "text": "یا پرہیزگاری کا حکم کرے تو۔ (منع کرنا کیسا)"
  },
  {
    "language": "Urdu",
    "translator": "Noor ul Amin",
    "text": "یاپرہیزگاری کا حکم دیتا ہو"
  },
  {
    "language": "Urdu",
    "translator": "Ahmad Raza Khan | Kanzul Eman",
    "text": "( ۱۲ )  یا پرہیزگاری بتاتا تو کیا خوب تھا ،"
  },
  {
    "language": "Urdu",
    "translator": "Dr. Tahir ul Qadri",
    "text": "یا وہ  ( لوگوں کو )  پرہیزگاری کا حکم دیتا  ( تو کیا خوب ہوتا )"
  },
  {
    "language": "Hindi",
    "translator": "Moulana Palanpuri",
    "text": "या परहेज़गारी का हुक्म दे (उस के अच्छा होने में क्या संदेह है)"
  },
  {
    "language": "English Sahih International",
    "translator": "",
    "text": "Or enjoins righteousness?"
  },
  {
    "language": "English",
    "translator": "Muhammad Junagarhi",
    "text": "Or enjoins righteousness?"
  },
  {
    "language": "English",
    "translator": "Abul A'la Maudoodi",
    "text": "and enjoins piety?"
  },
  {
    "language": "English",
    "translator": "Safi-ur-Rehman Mubarakpuri",
    "text": "Or enjoins Taqwa"
  },
  {
    "language": "English",
    "translator": "Muhammad William Pickthall",
    "text": "Or enjoineth piety?"
  },
  {
    "language": "English",
    "translator": "Muhammad Sarwar",
    "text": "or if he commands others to maintain piety!?"
  },
  {
    "language": "English",
    "translator": "Muhammad Habib Shakir",
    "text": "Or enjoined guarding (against evil)?"
  },
  {
    "language": "English",
    "translator": "Abdullah Yusuf Ali",
    "text": "Or enjoins Righteousness?"
  },
  {
    "language": "English",
    "translator": "Mufti Taqi Usmani",
    "text": "or bids piety, (would the former still forbid him?)"
  }
]