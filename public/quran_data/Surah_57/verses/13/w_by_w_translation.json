    "words": [
      {
        "arabic": "یَوۡمَ",
        "urdu": "جس دن"
      },
      {
        "arabic": "یَقُوۡلُ",
        "urdu": "کہیں گے"
      },
      {
        "arabic": "الۡمُنٰفِقُوۡنَ",
        "urdu": "منافق مرد"
      },
      {
        "arabic": "وَالۡمُنٰفِقٰتُ",
        "urdu": "اور منافق عورتیں"
      },
      {
        "arabic": "لِلَّذِیۡنَ",
        "urdu": "انہیں جو"
      },
      {
        "arabic": "اٰمَنُوا",
        "urdu": "ایمان لائے"
      },
      {
        "arabic": "انۡظُرُوۡنَا",
        "urdu": "انتظار کرو ہمارا"
      },
      {
        "arabic": "نَقۡتَبِسۡ",
        "urdu": "ہم روشنی حاصل کریں"
      },
      {
        "arabic": "مِنۡ نُّوۡرِکُمۡ",
        "urdu": "تمہارے نور سے"
      },
      {
        "arabic": "قِیۡلَ",
        "urdu": "کہہ دیا جائے گا"
      },
      {
        "arabic": "ارۡجِعُوۡا",
        "urdu": "لوٹ جاؤ"
      },
      {
        "arabic": "وَرَآءَکُمۡ",
        "urdu": "اپنے پیچھے"
      },
      {
        "arabic": "فَالۡتَمِسُوۡا",
        "urdu": "پھر تلاش کرو"
      },
      {
        "arabic": "نُوۡرًا",
        "urdu": "نور کو"
      },
      {
        "arabic": "فَضُرِبَ",
        "urdu": "تو حائل کر دی جائے گی"
      },
      {
        "arabic": "بَیۡنَہُمۡ",
        "urdu": "درمیان ان کے"
      },
      {
        "arabic": "بِسُوۡرٍ",
        "urdu": "ایک دیوار"
      },
      {
        "arabic": "لَّہٗ",
        "urdu": "اس کا"
      },
      {
        "arabic": "بَابٌ",
        "urdu": "ایک دروازہ ہوگا"
      },
      {
        "arabic": "بَاطِنُہٗ",
        "urdu": "اس کی اندرونی جانب"
      },
      {
        "arabic": "فِیۡہِ",
        "urdu": "جس میں"
      },
      {
        "arabic": "الرَّحۡمَۃُ",
        "urdu": "رحمت ہوگی"
      },
      {
        "arabic": "وَظَاہِرُہٗ",
        "urdu": "اور اس کی بیرونی جانب"
      },
      {
        "arabic": "مِنۡ قِبَلِہِ",
        "urdu": "اس طرف سے"
      },
      {
        "arabic": "الۡعَذَابُ",
        "urdu": "عذاب ہوگا"
      }
    ]
  },
